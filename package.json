{
  "name": "@jabrown93/homebridge-playstation",
  "displayName": "Playstation",
  "version": "1.8.0",
  "description": "Playstation integration for Homebridge",
  "type": "module",
  "keywords": [
    "homebridge-plugin"
  ],
  "bugs": {
    "url": "https://github.com/jabrown93/homebridge-playstation/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jabrown93/homebridge-playstation.git"
  },
  "license": "ISC",
  "author": {
    "email": "npm@jaredbrown.io",
    "name": "Jared Brown",
    "url": "https://github.com/jabrown93"
  },
  "contributors": [
    {
      "name": "Flavio De Stefano",
      "email": "destefano.flavio@gmail.com",
      "url": "https://www.kopiro.me"
    }
  ],
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "homebridge-playstation-login": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "config.schema.json"
  ],
  "scripts": {
    "prettier": "prettier --check .",
    "format": "prettier --write .",
    "lint": "eslint src/**.ts",
    "lint:fix": "eslint src/**.ts --fix",
    "clean": "rimraf ./dist",
    "compile": "tsc",
    "build": "npm-run-all clean compile",
    "watch": "npm run setup-config && npm run build && npm link && nodemon",
    "semantic-release": "cross-env semantic-release --no-ci",
    "release": "npm-run-all build semantic-release",
    "test": "echo \"Error: no test specified\" && exit 0",
    "prepare": "husky",
    "tsc": "tsc --noEmit",
    "setup-config": "if [ ! -f ./test/hbConfig/config.json ]; then cp ./test/hbConfig/config-template.json ./test/hbConfig/config.json; fi",
    "prepack": "npm-run-all clean compile"
  },
  "prettier": "@jabrown93/dev-config/prettier",
  "dependencies": {
    "async-lock": "^1.4.1",
    "playactor": "^0.4.1"
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@jabrown93/dev-config": "1.1.0",
    "@types/async": "3.2.25",
    "@types/async-lock": "1.4.2",
    "@types/js-yaml": "4.0.9",
    "@types/node": "24.13.3",
    "cross-env": "10.1.0",
    "eslint": "10.7.0",
    "homebridge": "2.2.1",
    "homebridge-config-ui-x": "5.27.0",
    "husky": "9.1.7",
    "lint-staged": "17.1.0",
    "nodemon": "3.1.14",
    "npm-run-all2": "9.0.2",
    "prettier": "3.9.5",
    "rimraf": "6.1.3",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  },
  "engines": {
    "homebridge": "^1.8.0 || ^2.0.0-beta.0",
    "node": "^22.12.0 || ^24.11.0 || ^26.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
